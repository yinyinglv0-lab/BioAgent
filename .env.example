# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# MySQL Database (optional - for disease DB integration)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=disease_db

# Agent Config
AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.3

# Logging
LOG_LEVEL=INFO
