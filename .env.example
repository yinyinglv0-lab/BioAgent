# ============================================
# BioAgent Configuration
# ============================================
# Choose your AI provider below. DeepSeek is free to start.
# ============================================

# Provider: "openai" (DeepSeek/GLM/Qwen/GPT) or "anthropic" (Claude)
AGENT_PROVIDER=openai
AGENT_MODEL=deepseek-chat

# === Option A: DeepSeek (China, free credits) ===
# 1. Register at https://platform.deepseek.com/
# 2. Go to API Keys -> Create Key
# 3. Paste your key below:
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com

# === Option B: Claude (if accessible) ===
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# === Option C: Other providers ===
# ZhipuAI (GLM):   OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# Qwen (Alibaba):   OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Moonshot (Kimi):  OPENAI_BASE_URL=https://api.moonshot.cn/v1

# Agent Config
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.3
LOG_LEVEL=INFO
